---
import { t, profile, type Lang } from '../i18n';

interface Props {
  lang: Lang;
  current: 'home' | 'publication';
}

const { lang, current } = Astro.props;
const tt = t[lang];
const path = current === 'home' ? '/' : '/publication/';
const other: Lang = lang === 'jp' ? 'en' : 'jp';
---

<header class="site-header">
  <div class="header-inner">
    <a class="site-name" href={`/${lang}/`}>{profile.name}</a>

    <div class="header-controls">
      <slot name="controls" />
    </div>

    <nav class="header-nav">
      <a href={`/${lang}/`} class:list={['tab', { active: current === 'home' }]}>
        {tt.nav.home}
      </a>
      <a
        href={`/${lang}/publication/`}
        class:list={['tab', { active: current === 'publication' }]}
      >
        {tt.nav.publication}
      </a>
      <a class="lang-switch" href={`/${other}${path}`}>⇄/{other}</a>
    </nav>
  </div>
</header>

<style>
  /* ヘッダー: 内容と同じ最大幅に揃える。境界線なし・縦幅広め */
  .site-header {
    position: sticky;
    top: 0;
    z-index: 10;
    background: var(--color-bg);
  }

  .header-inner {
    max-width: var(--site-width);
    margin: 0 auto;
    padding: 14px 24px;
    display: flex;
    align-items: center;
    gap: 24px;
    min-height: 76px;
  }

  .site-name {
    flex-shrink: 0;
    font-size: 1.05rem;
  }

  .header-controls {
    flex: 1;
    display: flex;
    justify-content: center;
    min-width: 0;
  }

  .header-nav {
    display: flex;
    align-items: center;
    gap: 16px;
    flex-shrink: 0;
  }

  /* タブ: 通常はグレー文字、選択中は黒文字（背景は付けない） */
  .tab {
    color: var(--color-muted);
  }

  .tab.active {
    color: var(--color-text);
  }

  .lang-switch {
    color: var(--color-muted);
    font-size: 0.9rem;
  }
</style>
