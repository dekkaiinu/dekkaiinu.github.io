---
import { t, profile, type Lang } from '../i18n';

interface Props {
  lang: Lang;
  current: 'home' | 'publication';
}

const { lang, current } = Astro.props;
const tt = t[lang];
const path = current === 'home' ? '/' : '/publication/';
const other: Lang = lang === 'jp' ? 'en' : 'jp';
const hasControls = Astro.slots.has('controls');
---

<header class="site-header">
  <div class="header-inner">
    <a class="site-name" href={`/${lang}/`}>
      <span class="name-en">{profile.name.en}</span>
      <span class="name-sep">/</span>
      <span class="name-ja">{profile.name.ja}</span>
    </a>

    {
      hasControls && (
        <div class="header-controls">
          <slot name="controls" />
        </div>
      )
    }

    <nav class="header-nav">
      <a href={`/${lang}/`} class:list={['tab', { active: current === 'home' }]}>
        {tt.nav.home}
      </a>
      <a
        href={`/${lang}/publication/`}
        class:list={['tab', { active: current === 'publication' }]}
      >
        {tt.nav.publication}
      </a>
      <a class="lang-switch" href={`/${other}${path}`}>⇄/{other}</a>
    </nav>
  </div>
</header>

<style>
  /* ヘッダー: 内容と同じ最大幅に揃える。境界線なし */
  .site-header {
    position: sticky;
    top: 0;
    z-index: 10;
    background: var(--color-bg);
  }

  /* flex-wrap で狭い画面でも横にはみ出さない */
  .header-inner {
    max-width: var(--site-width);
    margin: 0 auto;
    padding: 14px 24px;
    display: flex;
    align-items: center;
    flex-wrap: wrap;
    gap: 12px 24px;
    min-height: 76px;
  }

  /* 名前: 英字を大きく、日本語を相対的に小さく */
  .site-name {
    flex-shrink: 0;
    display: inline-flex;
    align-items: baseline;
    gap: 0.32em;
    font-size: 1.3rem;
  }

  .name-sep {
    color: var(--color-muted);
  }

  .name-ja {
    font-size: 0.82em;
  }

  .header-controls {
    flex: 1;
    display: flex;
    justify-content: center;
    min-width: 0;
  }

  /* タブ: 右寄せ（コントロール欄の有無に関わらず機能） */
  .header-nav {
    display: flex;
    align-items: center;
    gap: 16px;
    flex-shrink: 0;
    margin-left: auto;
  }

  .tab {
    color: var(--color-muted);
    font-size: 1.05rem;
  }

  .tab.active {
    color: var(--color-text);
  }

  .lang-switch {
    color: var(--color-muted);
    font-size: 1rem;
  }

  /* 中画面: コントロール欄（タグ・サイズ）を2段目へ折り返す */
  @media (max-width: 860px) {
    .header-nav {
      order: 1;
    }

    .header-controls {
      order: 2;
      flex: 0 0 100%;
    }
  }

  /* スマホ: 名前を縮小し、名前＋タブを1段目に収める */
  @media (max-width: 480px) {
    .header-inner {
      padding: 12px 16px;
      gap: 12px;
      min-height: 0;
    }

    .site-name {
      font-size: 1.1rem;
    }

    .header-nav {
      gap: 12px;
    }
  }
</style>
