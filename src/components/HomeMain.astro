---
import { t, profile, type Lang } from '../i18n';

interface Props {
  lang: Lang;
}

const { lang } = Astro.props;
const tt = t[lang];
---

<main class="home">
  <img class="photo" src="/images/photo.gif" alt="" />
  <div class="home-text">
    <p class="intro">{tt.intro}</p>

    <section class="block">
      <h2 class="block-title">{tt.sections.contact}</h2>
      <p class="contact">
        <a href={`mailto:${profile.email}`}>{profile.email}</a>
      </p>
    </section>

    <section class="block">
      <h2 class="block-title">{tt.sections.links}</h2>
      <ul class="links">
        {
          profile.links.map((l) => (
            <li>
              <a href={l.url} target="_blank" rel="noopener noreferrer">{l.label}</a>
            </li>
          ))
        }
      </ul>
    </section>

    <section class="block">
      <h2 class="block-title">{tt.sections.career}</h2>
      <ul class="career">
        {
          tt.career.map((c) => (
            <li class="career-item">
              <span class="career-period">{c.period}</span>
              <span class="career-org">{c.org}</span>
            </li>
          ))
        }
      </ul>
    </section>
  </div>
</main>

<style>
  /* 縦長(5:1)の画像を左に、テキストを右（上揃え）に配置 */
  .home {
    max-width: var(--site-width);
    margin: 0 auto;
    padding: 48px 24px;
    display: flex;
    align-items: flex-start;
    gap: 44px;
  }

  .photo {
    flex-shrink: 0;
    width: 200px;
    aspect-ratio: 1 / 5;
    object-fit: cover;
    border-radius: 6px;
  }

  .home-text {
    flex: 1;
    min-width: 0;
    /* Home のテキストはすべてグレーに統一 */
    color: var(--color-muted);
  }

  .intro {
    margin: 0 0 32px;
  }

  .block {
    margin: 0 0 28px;
  }

  .block:last-child {
    margin-bottom: 0;
  }

  .block-title {
    margin: 0 0 8px;
    font-size: 0.8rem;
    font-weight: 400;
    color: var(--color-muted);
  }

  .contact {
    margin: 0;
  }

  .links {
    margin: 0;
    padding: 0;
    list-style: none;
    display: flex;
    flex-direction: column;
    gap: 4px;
  }

  .career {
    margin: 0;
    padding: 0;
    list-style: none;
    display: flex;
    flex-direction: column;
    gap: 10px;
  }

  .career-item {
    display: flex;
    gap: 16px;
  }

  .career-period {
    flex-shrink: 0;
    width: 150px;
    color: var(--color-muted);
    font-size: 0.9rem;
    font-variant-numeric: tabular-nums;
  }

  .career-org {
    min-width: 0;
  }

  @media (max-width: 560px) {
    .home {
      gap: 24px;
      padding: 32px 20px;
    }

    .photo {
      width: 120px;
    }

    .career-item {
      flex-direction: column;
      gap: 2px;
    }

    .career-period {
      width: auto;
    }
  }
</style>
